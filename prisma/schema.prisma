generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String             @id @default(uuid())
  email          String             @unique
  passwordHash   String?
  name           String?
  role           UserRole           @default(USER)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  googleId       String?            @unique
  attempts       Attempt[]
  conversations  ChatConversation[]
  dailyProgress  DailyProgress[]
  folders        Folder[]
  supportTickets SupportTicket[]
  sessions       UserSession[]
  setting        UserSetting?
}

model GuestSession {
  id            String             @id @default(uuid())
  deviceId      String             @unique
  createdAt     DateTime           @default(now())
  attempts      Attempt[]
  conversations ChatConversation[]
  folders       Folder[]
}

model ChatConversation {
  id        String        @id @default(uuid())
  title     String?
  userId    String?
  guestId   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  guest     GuestSession? @relation(fields: [guestId], references: [id], onDelete: Cascade)
  user      User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId, updatedAt])
  @@index([guestId, updatedAt])
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String
  role           String
  content        String
  inputMode      String           @default("text")
  languageCode   String?
  audioMimeType  String?
  audioBase64    String?
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Language {
  code              String     @id
  name              String
  nativeName        String
  isSupported       Boolean    @default(true)
  googleCode        String?
  azureCode         String?
  color             String?
  flagEmoji         String?
  attempts          Attempt[]
  textItemsAsDest   TextItem[] @relation("DestLanguage")
  textItemsAsSource TextItem[] @relation("SourceLanguage")

  @@index([isSupported])
}

model Folder {
  id          String        @id @default(uuid())
  name        String
  description String?
  color       String?       @default("#3B82F6")
  icon        String?       @default("folder")
  userId      String?
  guestId     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  guest       GuestSession? @relation(fields: [guestId], references: [id], onDelete: Cascade)
  user        User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  textItems   TextItem[]

  @@index([userId])
  @@index([guestId])
}

model TextItem {
  id                String           @id @default(uuid())
  folderId          String
  originalText      String
  translatedText    String?
  sourceLang        String
  destLang          String?
  voiceType         VoiceType        @default(FEMALE)
  voiceProvider     String?
  voiceName         String?
  sampleAudioUrl    String?
  sampleAudioStatus ProcessingStatus @default(PENDING)
  sampleAudioError  String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  attempts          Attempt[]
  destLanguage      Language?        @relation("DestLanguage", fields: [destLang], references: [code])
  folder            Folder           @relation(fields: [folderId], references: [id], onDelete: Cascade)
  sourceLanguage    Language         @relation("SourceLanguage", fields: [sourceLang], references: [code])

  @@index([folderId])
  @@index([sourceLang])
  @@index([createdAt])
  @@index([sampleAudioStatus])
}

model Attempt {
  id                String           @id @default(uuid())
  textItemId        String
  userId            String?
  guestId           String?
  languageCode      String
  overallScore      Float?
  accuracyScore     Float?
  fluencyScore      Float?
  completenessScore Float?
  prosodyScore      Float?
  status            ProcessingStatus @default(PENDING)
  errorMessage      String?
  audioUrl          String?
  recognizedText    String?
  details           Json?
  audioDuration     Int?
  audioFormat       String?
  sampleRate        Int?
  isUsableForAI     Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  guest             GuestSession?    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  language          Language         @relation(fields: [languageCode], references: [code])
  textItem          TextItem         @relation(fields: [textItemId], references: [id], onDelete: Cascade)
  user              User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([textItemId])
  @@index([userId])
  @@index([guestId])
  @@index([userId, createdAt])
  @@index([guestId, createdAt])
  @@index([textItemId, createdAt])
  @@index([status])
  @@index([isUsableForAI])
  @@index([languageCode])
}

model UserSetting {
  id                  String    @id @default(uuid())
  userId              String    @unique
  theme               String    @default("system")
  language            String    @default("vi")
  dailyGoal           Int       @default(15)
  autoPlaySample      Boolean   @default(true)
  reminderEnabled     Boolean   @default(true)
  reminderTime        String?   @default("20:00")
  allowDataCollection Boolean   @default(false)
  nativeLanguage      String?   @default("vi")
  ageRange            AgeRange?
  gender              Gender?
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyProgress {
  id               String   @id @default(uuid())
  userId           String
  date             DateTime @db.Date
  attemptsCount    Int      @default(0)
  minutesPracticed Int      @default(0)
  goalMet          Boolean  @default(false)
  streakDay        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model TranslationCache {
  id         String   @id @default(uuid())
  textHash   String
  sourceLang String
  targetLang String
  result     Json
  createdAt  DateTime @default(now())

  @@unique([textHash, sourceLang, targetLang])
  @@index([createdAt])
}

model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  valueType   String   @default("string")
  description String?
  updatedAt   DateTime @updatedAt
}

model SupportTicket {
  id         String         @id @default(uuid())
  userId     String?
  email      String
  name       String?
  subject    String
  message    String
  category   TicketCategory @default(GENERAL)
  status     TicketStatus   @default(OPEN)
  adminReply String?
  repliedAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  user       User?          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  userAgent    String?
  ipAddress    String?
  tokenHash    String   @unique
  isActive     Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum VoiceType {
  MALE
  FEMALE
  NEUTRAL
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum UserRole {
  USER
  ADMIN
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketCategory {
  GENERAL
  PRONUNCIATION
  ACCOUNT
  PAYMENT
  BUG_REPORT
  FEATURE_REQUEST
}

enum ProcessingStatus {
  NOT_QUEUED
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AgeRange {
  AGE_13_17
  AGE_18_24
  AGE_25_34
  AGE_35_44
  AGE_45_PLUS
}
