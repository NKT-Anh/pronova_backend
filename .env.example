# ============================================================
# App
# ============================================================
PORT=3000
NODE_ENV=development

# Swagger docs
# Development can keep docs enabled. In production, keep this false or set
# SWAGGER_USERNAME/SWAGGER_PASSWORD to protect /api/docs.
SWAGGER_ENABLED=true
SWAGGER_USERNAME=
SWAGGER_PASSWORD=

# ============================================================
# Database
# Prisma 7 reads this through prisma.config.ts.
# ============================================================
DATABASE_URL=postgresql://postgres:anhanh@localhost:5432/pronunciation_db
DB_PASSWORD=anhanh

# ============================================================
# Auth
# Use a long random secret in real environments.
# ============================================================
JWT_SECRET=replace-with-a-long-random-secret

# ============================================================
# Azure Speech Pronunciation Assessment
# Used by /api/speech/analyze and /api/speech/attempts/:attemptId/score.
# ============================================================
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ============================================================
# Python AI Pronunciation Assessment Service
# Used by /api/speech/analyze, /api/speech/analyze-free,
# and /api/speech/attempts/:attemptId/score.
# Local:  http://localhost:8000
# Docker: http://ai-service:8000
# ============================================================
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT_MS=60000
AI_ASSESSMENT_PROVIDER=whisper_text
# Options: whisper_text | google_stt_text | external_text

# ============================================================
# Google Speech-to-Text
# Used by /api/speech/transcribe.
# Create a Google Cloud service account JSON key and point to it here.
# Keep the JSON key out of git. Suggested local path:
# F:\Projects\2026\PersonalPronunciationCoach\backend\keys\google-service-account.json
# ============================================================
GOOGLE_APPLICATION_CREDENTIALS=F:\Projects\2026\PersonalPronunciationCoach\backend\keys\google-service-account.json

# ============================================================
# Gemini API
# Split keys by capability when possible. The fallback order keeps local
# development simple, but production should use separate keys for rotation.
# ============================================================
GEMINI_API_KEY=
GEMINI_CHAT_API_KEY=
GEMINI_SPEECH_TO_TEXT_API_KEY=
GEMINI_TEXT_TO_SPEECH_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_TRANSCRIBE_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_SPEECH_TO_TEXT_MODEL=gemini-2.5-flash
GEMINI_TEXT_TO_SPEECH_MODEL=gemini-2.5-flash-preview-tts

# ============================================================
# SMTP Support Email
# Used by support tickets and forgot-password OTP email.
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SUPPORT_ADMIN_EMAIL=
